# Copy to .env.local inside apps/web (Next.js) or export in your shell.

# PostgreSQL connection (docker-compose default shown)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/claritypath

# Optional: run the web app with fictional in-memory demo fixtures instead of
# Postgres. This is useful when Docker/Postgres are not installed locally.
# CLARITY_DATA_MODE=fixture

# Privacy default: user-entered care data stays local in the browser vault.
# Database-backed care-data reads are disabled unless this is explicitly set.
# CLARITY_STORAGE_MODE=cloud

# --- Auth placeholders (not yet wired; dev login is used locally) ---
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=

# Never commit real secrets. .env* files are gitignored.
